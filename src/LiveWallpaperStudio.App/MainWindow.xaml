<Window x:Class="LiveWallpaperStudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wallora - Live wallpaper"
        Icon="Assets/Brand/app-icon.ico"
        Width="1180"
        Height="680"
        MinWidth="1040"
        MinHeight="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Border Background="{StaticResource AppBg}" BorderBrush="#334258" BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="8" Opacity="0.35" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.RowSpan="2" Background="#091420" CornerRadius="10,0,0,10" BorderBrush="#172435" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="72" />
                    </Grid.RowDefinitions>

                    <Image Source="Assets/Brand/primary-horizontal-logo.png"
                           Width="154"
                           Height="42"
                           Margin="20,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />

                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <RadioButton x:Name="HomeNav" Style="{StaticResource NavButton}" IsChecked="True" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE80F;" Width="24" />
                                <TextBlock Text="Home" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="LibraryNav" Style="{StaticResource NavButton}" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE8A5;" Width="24" />
                                <TextBlock Text="Library" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="DisplaysNav" Style="{StaticResource NavButton}" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE7F4;" Width="24" />
                                <TextBlock Text="Displays" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="PerformanceNav" Style="{StaticResource NavButton}" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE9D9;" Width="24" />
                                <TextBlock Text="Performance" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="SettingsNav" Style="{StaticResource NavButton}" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE713;" Width="24" />
                                <TextBlock Text="Settings" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <Button Grid.Row="2" Margin="18,12" Style="{StaticResource GhostButton}" Height="42">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE734;" FontSize="14" />
                            <TextBlock Text="Get Pro" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                    <Image Source="Assets/Brand/app-mark.png"
                           Width="34"
                           Height="24"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Wallora - Live wallpaper" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedText}" FontSize="12" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource SmallIconButton}" Width="32" Height="28" ToolTip="Minimize" Click="Minimize_Click">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE921;" FontSize="12" />
                </Button>
                <Button Grid.Column="2" Style="{StaticResource SmallIconButton}" Width="32" Height="28" ToolTip="Maximize or restore" Click="Maximize_Click">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE922;" FontSize="12" />
                </Button>
                <Button Grid.Column="3" Style="{StaticResource CloseIconButton}" Width="32" Height="28" ToolTip="Close to tray" Click="Close_Click">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8BB;" FontSize="12" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1" Margin="28,14,28,28">
                <Grid x:Name="HomePage">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="76" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Home" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="Enjoy your live wallpapers." Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}" ClipToBounds="True">
                        <Grid>
                            <Image x:Name="HomePreviewImage" Source="Assets/Mockups/01-main-app-ui-mockup.png" Stretch="UniformToFill" />
                            <Border Width="48" Height="48" CornerRadius="24" Background="#AA000000" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="20">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE769;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" />
                            </Border>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#AA101A27" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE713;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="16,0,0,0" Padding="22">
                        <StackPanel>
                            <TextBlock Text="Current Wallpaper" Foreground="{StaticResource MutedText}" />
                            <TextBlock x:Name="CurrentWallpaperName" Text="No wallpaper selected" FontSize="22" FontWeight="Bold" Margin="0,14,0,0" />
                            <TextBlock x:Name="PlaybackStatus" Text="Stopped" Foreground="{StaticResource MutedText}" Margin="0,10,0,18" />
                            <TextBlock x:Name="MonitorStatus" Text="▣  Monitors detected after launch" Margin="0,9" />
                            <TextBlock x:Name="RendererAttachStatus" Text="Desktop layer not attached" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,9" />
                            <TextBlock x:Name="ScaleModeStatus" Text="□  Fill / Cover" Margin="0,9" />
                            <TextBlock x:Name="PerformanceModeStatus" Text="Balanced Mode" Margin="0,9,0,24" />
                            <Button x:Name="PauseButton" Style="{StaticResource PrimaryButton}" Click="Pause_Click" />
                            <Button Style="{StaticResource GhostButton}" Margin="0,12,0,0" Click="AddWallpaper_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE70F;" FontSize="14" />
                                    <TextBlock Text="Change" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Margin="0,12,0,0" Click="OpenLibrary_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8A5;" FontSize="14" />
                                    <TextBlock Text="Open Library" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="LibraryPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="84" />
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Library" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="Manage and organize your wallpapers." Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource PrimaryButton}" Width="170" Click="AddWallpaper_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" FontSize="14" />
                                <TextBlock Text="Add Wallpaper" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SmallIconButton}" Margin="10,0,0,0" ToolTip="Grid view" IsEnabled="False">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE8A9;" FontSize="14" />
                        </Button>
                        <Button Style="{StaticResource SmallIconButton}" Margin="8,0,0,0" ToolTip="List view coming after screenshot QA" IsEnabled="False">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE8FD;" FontSize="14" />
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Height="42" Width="420" HorizontalAlignment="Left" Style="{StaticResource Card}" Padding="14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE721;" Foreground="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="Search wallpapers..." Foreground="{StaticResource MutedText}" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource Text}"
                                     CaretBrush="{StaticResource Text}"
                                     VerticalContentAlignment="Center"
                                     TextChanged="SearchBox_TextChanged" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                        <ScrollViewer Style="{StaticResource ThemedScrollViewer}">
                            <WrapPanel x:Name="LibraryItemsPanel" />
                        </ScrollViewer>
                        <Border x:Name="LibraryEmptyState" Style="{StaticResource Card}" Padding="28" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Your library is empty" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="Add an image or video wallpaper to start building your collection." Foreground="{StaticResource MutedText}" Margin="0,8,0,18" />
                                <Button Style="{StaticResource PrimaryButton}" Width="180" HorizontalAlignment="Left" Click="AddWallpaper_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" FontSize="14" />
                                        <TextBlock Text="Add Wallpaper" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="14,10" Background="#101A27" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE8A5;" Foreground="{StaticResource MutedText}" FontSize="13" />
                            <TextBlock Text="Supported files: images .jpg, .jpeg, .png, .bmp  |  videos .mp4, .webm"
                                       Foreground="{StaticResource MutedText}"
                                       FontSize="12"
                                       Margin="10,0,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="DisplaysPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="84" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Displays" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="Configure your monitors and wallpaper settings." Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Style="{StaticResource ThemedScrollViewer}" Padding="0,0,10,0">
                        <StackPanel>
                            <WrapPanel x:Name="MonitorCardsPanel" />
                            <StackPanel Margin="0,24,0,0">
                                <TextBlock Text="Wallpaper mode" FontSize="18" FontWeight="Bold" />
                                <UniformGrid x:Name="WallpaperModePanel" Columns="3" Margin="0,12,0,0" />
                            </StackPanel>
                            <Border Style="{StaticResource Card}" Margin="0,24,0,24" Padding="18" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Per-monitor settings" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Text="Choose wallpapers and scale behavior for each connected monitor." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    <Border x:Name="MonitorProfilesEmptyState" Background="#101A27" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,14,0,0" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource IconText}" Text="&#xE7F4;" Foreground="{StaticResource MutedText}" />
                                            <TextBlock Text="No monitor assignments yet. Choose a wallpaper for a monitor to create one." Foreground="{StaticResource MutedText}" Margin="10,0,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel x:Name="MonitorProfilesPanel" Margin="0,14,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="PerformancePage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="84" />
                        <RowDefinition Height="112" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Performance" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="Optimize performance and playback behavior." Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>
                    <UniformGrid x:Name="PerformancePresetPanel" Grid.Row="1" Columns="4" />
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,20,0,0" Padding="18" VerticalAlignment="Top">
                        <StackPanel>
                            <CheckBox x:Name="PauseFullscreenCheckBox" Content="Pause when fullscreen app is running" Margin="0,8" Checked="PauseRule_Changed" Unchecked="PauseRule_Changed" />
                            <CheckBox x:Name="PauseGameCheckBox" Content="Pause when game is running" Margin="0,8" Checked="PauseRule_Changed" Unchecked="PauseRule_Changed" />
                            <CheckBox x:Name="PauseBatteryCheckBox" Content="Pause when laptop is on battery" Margin="0,8" Checked="PauseRule_Changed" Unchecked="PauseRule_Changed" />
                            <CheckBox x:Name="PauseLockCheckBox" Content="Pause when screen is locked" Margin="0,8" Checked="PauseRule_Changed" Unchecked="PauseRule_Changed" />
                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                <TextBlock Text="Target FPS" FontWeight="Bold" VerticalAlignment="Center" Width="160" />
                                <StackPanel x:Name="FpsPanel" Orientation="Horizontal" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="84" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Settings" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="Startup, tray behavior, engine recovery, and diagnostics." Foreground="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Style="{StaticResource ThemedScrollViewer}" Padding="0,0,10,0">
                        <Border Style="{StaticResource Card}" Padding="22" VerticalAlignment="Top" Margin="0,0,0,24">
                            <StackPanel>
                                <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows" Margin="0,8" Checked="GeneralSetting_Changed" Unchecked="GeneralSetting_Changed" />
                                <CheckBox x:Name="MinimizeToTrayCheckBox" Content="Minimize to tray" Margin="0,8" Checked="GeneralSetting_Changed" Unchecked="GeneralSetting_Changed" />
                                <CheckBox x:Name="KeepRunningCheckBox" Content="Keep wallpaper running when app window is closed" Margin="0,8" Checked="GeneralSetting_Changed" Unchecked="GeneralSetting_Changed" />
                                <TextBlock Text="Default scale mode" FontSize="18" FontWeight="Bold" Margin="0,24,0,0" />
                                <UniformGrid x:Name="ScaleModePanel" Columns="4" Margin="0,12,0,0" />
                                <Button Style="{StaticResource PrimaryButton}" Width="240" HorizontalAlignment="Left" Margin="0,24,0,0" Click="StopEngine_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE71A;" FontSize="14" />
                                        <TextBlock Text="Stop wallpaper engine" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" Width="240" HorizontalAlignment="Left" Margin="0,12,0,0" Click="Reattach_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE72C;" FontSize="14" />
                                        <TextBlock Text="Reattach to desktop" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <WrapPanel Margin="0,18,0,0">
                                    <Button Style="{StaticResource GhostButton}" Content="Clear thumbnail cache" Width="190" Margin="0,0,10,10" Click="ClearThumbnailCache_Click" />
                                    <Button Style="{StaticResource GhostButton}" Content="Open data folder" Width="170" Margin="0,0,10,10" Click="OpenDataFolder_Click" />
                                    <Button Style="{StaticResource GhostButton}" Content="Export diagnostics" Width="180" Margin="0,0,10,10" Click="ExportDiagnostics_Click" />
                                    <Button Style="{StaticResource GhostButton}" Content="Reset settings" Width="150" Margin="0,0,10,10" Click="ResetSettings_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <Border x:Name="StatusBanner" Background="#E6101A27" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="14,10" HorizontalAlignment="Right" VerticalAlignment="Top" MaxWidth="420" Visibility="Collapsed">
                    <DockPanel>
                        <TextBlock x:Name="StatusBannerIcon" Style="{StaticResource IconText}" Text="&#xE946;" Margin="0,0,10,0" />
                        <TextBlock x:Name="StatusBannerText" Text="Ready" TextWrapping="Wrap" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

